# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Security
SECRET_KEY=your-secret-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ⭐ NEW: Day Cutoff Time (เวลาตัดรอบวันใหม่)
# ถ้าเวลาปัจจุบัน < DAY_CUTOFF_TIME → ถือว่าเป็นงวดของเมื่อวาน
# ถ้าเวลาปัจจุบัน >= DAY_CUTOFF_TIME → ถือว่าเป็นงวดของวันนี้
# ตัวอย่าง: 05:20:00 = ตัดรอบเวลา 5:20 น.
DAY_CUTOFF_TIME=05:20:00
